# ----- ListLift environment -----
# Copy to .env and fill in. With NO keys set, the app runs in MOCK MODE
# (templated sample listing + simulated checkout) so the full funnel is testable.

# Anthropic (production listing generation)
ANTHROPIC_API_KEY=
# Model id — sonnet for quality, haiku for cheap/fast. Default: claude-sonnet-4-6
LISTLIFT_MODEL=claude-sonnet-4-6

# Stripe — TEST MODE keys only (sk_test_... / pk_test_...). Do NOT use live keys.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Optional: a pre-made Price id for the $39 pack. If empty, a price is created inline.
STRIPE_PRICE_ID=

# Public base URL of the deployment (used for Stripe success/cancel redirects)
PUBLIC_BASE_URL=http://localhost:3000

# Server port
PORT=3000
